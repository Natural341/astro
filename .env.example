# Gemini AI
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key

# Go Backend
EXPO_PUBLIC_GO_BACKEND_URL=http://localhost:8080

# Local LLM (optional, dev only — e.g., LM Studio on WiFi LAN)
# EXPO_PUBLIC_LOCAL_LLM_URL=http://192.168.1.X:1234

# Cloud LLM — free Gemini alternative (Groq). Get a free key at console.groq.com
# Used as the primary text engine; falls back to Gemini if unset or on error.
# EXPO_PUBLIC_LLM_BASE_URL=https://api.groq.com/openai/v1
# EXPO_PUBLIC_LLM_API_KEY=gsk_xxx
# EXPO_PUBLIC_LLM_MODEL=llama-3.3-70b-versatile

# Sentry crash/error monitoring (optional; no-op if unset).
# Native reporting requires a development build — does NOT work in Expo Go.
# Get a free DSN at sentry.io
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# RevenueCat
EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=your_rc_google_key
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=your_rc_apple_key

# AdMob
EXPO_PUBLIC_ADMOB_APP_ID_ANDROID=ca-app-pub-xxx~xxx
EXPO_PUBLIC_ADMOB_APP_ID_IOS=ca-app-pub-xxx~xxx
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=ca-app-pub-xxx/xxx
EXPO_PUBLIC_ADMOB_BANNER_IOS=ca-app-pub-xxx/xxx
EXPO_PUBLIC_ADMOB_REWARD_VIDEO_ANDROID=ca-app-pub-xxx/xxx
EXPO_PUBLIC_ADMOB_REWARD_VIDEO_IOS=ca-app-pub-xxx/xxx
