Options -MultiViews
RewriteEngine On

# Mevcut dosyaysa direkt sun
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Klasörse direkt sun
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# HTML versiyonu varsa sun (Next.js static export: /login → /login.html veya /login/index.html)
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.*)$ $1/index.html [L]

# Yoksa index.html'e yönlendir (SPA fallback)
RewriteRule ^ index.html [L]
